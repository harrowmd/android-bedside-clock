<?xml version="1.0" encoding="utf-8"?>
<paths>
    <!-- public Documents folder: /sdcard/Documents/ — where Logger actually writes
         the log when MANAGE_EXTERNAL_STORAGE is granted (the normal setup) -->
    <external-path name="public_docs" path="Documents/" />
    <!-- app-specific external storage: /sdcard/Android/data/com.manytwo.besideclock/files/ -->
    <external-files-path name="logs" path="." />
    <!-- app-specific internal storage fallback -->
    <files-path name="logs_internal" path="." />
</paths>
