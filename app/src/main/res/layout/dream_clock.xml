<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:keepScreenOn="true">

    <!-- ══ Single-line clock  (sizes S / M / L) ══ -->
    <LinearLayout
        android:id="@+id/layout_single"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:gravity="center">

        <TextClock
            android:id="@+id/tv_time_single"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:format24Hour="HH:mm"
            android:format12Hour="h:mm"
            android:textSize="96sp"
            android:textColor="#FFAA00"
            android:fontFamily="sans-serif-thin"
            android:includeFontPadding="false"
            android:letterSpacing="0.04" />

        <TextView
            android:id="@+id/tv_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textSize="20sp"
            android:textColor="#FFAA00"
            android:fontFamily="sans-serif-thin" />

    </LinearLayout>

    <!-- ══ Giant two-line clock  (size XL) ══ -->
    <LinearLayout
        android:id="@+id/layout_giant"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone">

        <!-- Hour line: e.g. "08:" -->
        <TextClock
            android:id="@+id/tv_hour"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:format24Hour="HH:"
            android:format12Hour="h:"
            android:textSize="160sp"
            android:textColor="#FFAA00"
            android:fontFamily="sans-serif-thin"
            android:includeFontPadding="false" />

        <!-- Minute line: e.g. "54" -->
        <TextClock
            android:id="@+id/tv_minute"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:format24Hour="mm"
            android:format12Hour="mm"
            android:textSize="160sp"
            android:textColor="#FFAA00"
            android:fontFamily="sans-serif-thin"
            android:includeFontPadding="false" />

        <TextView
            android:id="@+id/tv_date_giant"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textSize="20sp"
            android:textColor="#FFAA00"
            android:fontFamily="sans-serif-thin" />

    </LinearLayout>

    <!-- ══ Battery indicator — top-right ══ -->
    <TextView
        android:id="@+id/tv_battery"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:padding="20dp"
        android:textSize="14sp"
        android:textColor="#FFAA00"
        android:text="..." />

    <!-- ══ Settings gear button — bottom-right ══ -->
    <TextView
        android:id="@+id/btn_settings"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:padding="24dp"
        android:text="⚙"
        android:textSize="22sp"
        android:textColor="#44FFFFFF"
        android:clickable="true"
        android:focusable="true" />

    <!-- ══ Settings overlay (hidden until gear is tapped) ══ -->
    <FrameLayout
        android:id="@+id/overlay_settings"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <!-- Dim backdrop — tap to close settings without changing anything -->
        <View
            android:id="@+id/backdrop"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#99000000"
            android:clickable="true"
            android:focusable="true" />

        <!-- Settings panel slides up from the bottom -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:scrollbars="none"
            android:clickable="true"
            android:focusable="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#F2111111"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="16dp"
                android:paddingBottom="24dp">

                <!-- Header: title + dismiss -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="20dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Clock Settings"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF" />

                    <TextView
                        android:id="@+id/btn_dismiss"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Dismiss clock  ✕"
                        android:textSize="13sp"
                        android:textColor="#888888"
                        android:clickable="true"
                        android:focusable="true" />

                </LinearLayout>

                <!-- COLOUR ────────────────────────────── -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="COLOUR"
                    android:textSize="11sp"
                    android:textColor="#555555"
                    android:letterSpacing="0.12"
                    android:layout_marginBottom="10dp" />

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none"
                    android:layout_marginBottom="20dp">

                    <LinearLayout
                        android:id="@+id/row_colors"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical" />

                </HorizontalScrollView>

                <!-- BRIGHTNESS ────────────────────────── -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BRIGHTNESS"
                    android:textSize="11sp"
                    android:textColor="#555555"
                    android:letterSpacing="0.12"
                    android:layout_marginBottom="10dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="☾"
                        android:textSize="16sp"
                        android:textColor="#555555"
                        android:layout_marginEnd="12dp" />

                    <SeekBar
                        android:id="@+id/slider_brightness"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:max="100"
                        android:progress="15" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="☀"
                        android:textSize="16sp"
                        android:textColor="#555555"
                        android:layout_marginStart="12dp" />

                </LinearLayout>

                <!-- FONT ──────────────────────────────── -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="FONT"
                    android:textSize="11sp"
                    android:textColor="#555555"
                    android:letterSpacing="0.12"
                    android:layout_marginBottom="10dp" />

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none"
                    android:layout_marginBottom="20dp">

                    <LinearLayout
                        android:id="@+id/row_fonts"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical" />

                </HorizontalScrollView>

                <!-- SIZE ──────────────────────────────── -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SIZE  —  XL splits to two lines"
                    android:textSize="11sp"
                    android:textColor="#555555"
                    android:letterSpacing="0.12"
                    android:layout_marginBottom="10dp" />

                <LinearLayout
                    android:id="@+id/row_sizes"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical" />

            </LinearLayout>

        </ScrollView>

    </FrameLayout>

</FrameLayout>
